# Application
APP_NAME=AgenticAI
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-super-secret-key-change-this
APP_PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./vector_store/chroma

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Alternative LLM (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# Tools
SERPAPI_API_KEY=your-serpapi-key
WEATHER_API_KEY=your-weather-api-key
NEWS_API_KEY=your-news-api-key

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/agentic_ai.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Monitoring
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# WebSocket
WS_MAX_CONNECTIONS=1000
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=60

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.txt,.md,.csv,.json

# Caching
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Agent Configuration
MAX_ITERATIONS=10
MAX_REFLECTION_DEPTH=3
AGENT_TIMEOUT=60
MEMORY_SHORT_TERM_CAPACITY=100
MEMORY_LONG_TERM_BATCH_SIZE=50

# RAG Configuration
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=AgenticAI
